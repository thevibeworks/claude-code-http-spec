GET {{claudeAiUrl}}/api/web/domain_info?domain={{domain}}

### Response:
# {
#   "can_fetch": true
# }


### ============================================================================
### SECTION 18: FEATURE FLAGS (GrowthBook)
### ============================================================================
# Pattern: rg "api/features|api/eval" cli.js

### ----------------------------------------------------------------------------
### 18.1 Fetch Features
### ----------------------------------------------------------------------------

# @name fetchFeatures
GET {{baseUrl}}/api/features/{{clientKey}}

### ----------------------------------------------------------------------------
### 18.2 Remote Eval
### ----------------------------------------------------------------------------

# @name remoteEval
POST {{baseUrl}}/api/eval/{{clientKey}}
Content-Type: application/json

{
    "attributes": {}
}


### ============================================================================
### SECTION 19: TOKEN REVOCATION (OAuth 2.0 RFC 7009)
### ============================================================================
# Pattern: rg "revocation_endpoint|token_type_hint" cli.js
# Discovered via OAuth metadata at /.well-known/oauth-authorization-server

### ----------------------------------------------------------------------------
### 19.1 Revoke Access Token
### ----------------------------------------------------------------------------

# @name revokeAccessToken
POST {{consoleUrl}}/v1/oauth/revoke
Content-Type: application/x-www-form-urlencoded
Authorization: Bearer {{accessToken}}

token={{accessToken}}&token_type_hint=access_token&client_id={{clientId}}

### ----------------------------------------------------------------------------
### 19.2 Revoke Refresh Token
### ----------------------------------------------------------------------------

# @name revokeRefreshToken
POST {{consoleUrl}}/v1/oauth/revoke
Content-Type: application/x-www-form-urlencoded
Authorization: Bearer {{accessToken}}

token={{refreshToken}}&token_type_hint=refresh_token&client_id={{clientId}}


### ============================================================================
### SECTION 20: OAUTH METADATA DISCOVERY
### ============================================================================
# Pattern: rg "well-known/oauth-authorization-server" cli.js

### ----------------------------------------------------------------------------
### 20.1 OAuth Authorization Server Metadata
### ----------------------------------------------------------------------------

# @name oauthMetadata
GET {{consoleUrl}}/.well-known/oauth-authorization-server

### Response includes:
# {
#   "issuer": "...",
#   "authorization_endpoint": "...",
#   "token_endpoint": "...",
#   "revocation_endpoint": "...",
#   "scopes_supported": [...],
#   ...
# }


### ============================================================================
### SECTION 21: BINARY DISTRIBUTION (CDN)
### ============================================================================
# Pattern: rg "downloads\.claude\.ai|storage\.googleapis\.com.*claude-code" cli.js

### ----------------------------------------------------------------------------
### 21.1 Fetch Version (Stable/Latest)
### ----------------------------------------------------------------------------
# Primary CDN
# GET https://downloads.claude.ai/claude-code-releases/stable
# GET https://downloads.claude.ai/claude-code-releases/latest
#
# Fallback GCS
# GET https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/stable

# @name fetchVersion
GET https://downloads.claude.ai/claude-code-releases/stable

### ----------------------------------------------------------------------------
### 21.2 Fetch Manifest
### ----------------------------------------------------------------------------

# @name fetchManifest
GET https://downloads.claude.ai/claude-code-releases/{{version}}/manifest.json

### Response:
# {
#   "platforms": {
#     "darwin-arm64": { "checksum": "..." },
#     "darwin-x64": { "checksum": "..." },
#     "linux-arm64": { "checksum": "..." },
#     "linux-x64": { "checksum": "..." },
#     "win32-x64": { "checksum": "..." }
#   }
# }

### ----------------------------------------------------------------------------
### 21.3 Download Binary
### ----------------------------------------------------------------------------

# @name downloadBinary
GET https://downloads.claude.ai/claude-code-releases/{{version}}/{{platform}}/{{filename}}


