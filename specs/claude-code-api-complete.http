GET https://featureassets.org/v1/initialize

# @name statsigConfigSpecs
GET https://api.statsigcdn.com/v1/download_config_specs

# @name statsigRegistry
GET https://prodregistryv2.org/v1/rgstr


### ============================================================================
### SECTION 23: DOCUMENTATION FETCHING
### ============================================================================
# Pattern: rg "raw\.githubusercontent\.com|code\.claude\.com/docs|docs\.claude\.com" cli.js

### ----------------------------------------------------------------------------
### 23.1 Changelog
### ----------------------------------------------------------------------------

# @name fetchChangelog
GET https://raw.githubusercontent.com/anthropics/claude-code/refs/heads/main/CHANGELOG.md

### ----------------------------------------------------------------------------
### 23.2 Claude Code Docs Map
### ----------------------------------------------------------------------------

# @name fetchDocsMap
GET https://code.claude.com/docs/en/claude_code_docs_map.md

### ----------------------------------------------------------------------------
### 23.3 Agent SDK Docs Map
### ----------------------------------------------------------------------------

# @name fetchAgentSdkDocsMap
GET https://docs.claude.com/en/api/agent_sdk_docs_map.md


### ============================================================================
### SECTION 24: SESSION PERSISTENCE (with Session Token)
### ============================================================================
# Pattern: rg "session_ingress|Last-Uuid" cli.js

### ----------------------------------------------------------------------------
### 24.1 Persist Session Log Entry (PUT)
### ----------------------------------------------------------------------------
# Used for session log synchronization with Last-Uuid header for conflict detection

# @name persistSessionLog
PUT {{baseUrl}}/v1/session_ingress/session/{{sessionId}}
Authorization: Bearer {{sessionToken}}
Content-Type: application/json
Last-Uuid: {{lastUuid}}

{
    "uuid": "{{entryUuid}}",
    "data": {}
}

### Response:
# 200/201 - Success
# 409 - Conflict (UUID mismatch)
# 401 - Token expired

### ----------------------------------------------------------------------------
### 24.2 Fetch Session Logs
### ----------------------------------------------------------------------------
# Same URL as PUT, different method - GET fetches, PUT persists

# @name fetchSessionLogs
GET {{baseUrl}}/v1/session_ingress/session/{{sessionId}}
Authorization: Bearer {{sessionToken}}

### Response:
# {
#   "loglines": [...]
# }


### ============================================================================
### SECTION 25: NETWORK CONNECTIVITY CHECK
### ============================================================================
# Pattern: rg "1\.1\.1\.1|EHOSTUNREACH" cli.js

### ----------------------------------------------------------------------------
### 25.1 Cloudflare DNS Check (Network Connectivity)
### ----------------------------------------------------------------------------

# @name cloudflareCheck
HEAD http://1.1.1.1


### ============================================================================
### SECTION 26: PLUGIN MARKETPLACE (User-Configured URLs)
### ============================================================================
# Pattern: rg "Plugin-Manager|\.mcpb" cli.js
#
# These are NOT fixed Anthropic endpoints - they are user-provided URLs:
# - Marketplace: user adds via "/plugin marketplace add <path/url>"
# - MCPB bundles: user-specified .mcpb or .dxt files (local or remote)

### ----------------------------------------------------------------------------
### 26.1 Fetch Plugin Marketplace (user-provided URL)
### ----------------------------------------------------------------------------

# @name fetchMarketplace
# URL is user-configured, not a fixed endpoint
GET {{marketplaceUrl}}
User-Agent: Claude-Code-Plugin-Manager

### ----------------------------------------------------------------------------
### 26.2 Download MCPB Bundle (user-provided URL)
### ----------------------------------------------------------------------------
# URL must end with .mcpb or .dxt

# @name downloadMcpb
# URL is user-configured, not a fixed endpoint
GET {{mcpbUrl}}


