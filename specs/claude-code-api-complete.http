# Claude Code CLI - Complete API Reference
# Extracted from @anthropic-ai/claude-code v2.1.197
#
# Validation: Search for URL path strings (stable across builds)
#   strings binary_2.1.197/claude | rg '/api/oauth/profile'
#   strings binary_2.1.197/claude | rg '"/v1/messages"'
#   strings binary_2.1.197/claude | rg 'api\.anthropic\.com'
# (Older wrapper packages shipped a readable cli.js; the same patterns apply
#  to that file: rg '/api/oauth/profile' package/cli.js)
#
# See: WORKFLOW.md for extraction workflow with HTTP precision requirements

### ============================================================================
### VARIABLES
### ============================================================================

@baseUrl = https://api.anthropic.com
@platformUrl = https://platform.claude.com
@claudeAiUrl = https://claude.ai
@mcpProxyUrl = https://mcp-proxy.anthropic.com
@bridgeWsUrl = wss://bridge.claudeusercontent.com
@version = 2023-06-01
@oauthBeta = oauth-2025-04-20
@mcpBeta = mcp-servers-2025-12-04
@compactBeta = compact-2026-01-12
@clientId = 9d1c250a-e61b-44d9-88ed-5944d1962f5e
@stainlessVersion = 0.74.0
@managedAgentsBeta = managed-agents-2026-04-01
@cliVersion = 2.1.197

# Auth tokens (set these)
@accessToken = YOUR_ACCESS_TOKEN
@apiKey = YOUR_API_KEY
@orgUuid = YOUR_ORG_UUID
@remoteSettingsChecksum = sha256:YOUR_CHECKSUM


### ============================================================================
### SECTION 1: OAUTH FLOW
### ============================================================================
# Pattern: rg "oauth/authorize|oauth/token" cli.js

### ----------------------------------------------------------------------------
### 1.1 Authorization URL (Browser redirect - not a direct request)
### ----------------------------------------------------------------------------
# Pattern: rg "CONSOLE_AUTHORIZE_URL|CLAUDE_AI_AUTHORIZE_URL" cli.js
#
# Platform OAuth (v2.1.22+: console.anthropic.com → platform.claude.com):
#   https://platform.claude.com/oauth/authorize
#     ?code=true
#     &client_id=9d1c250a-e61b-44d9-88ed-5944d1962f5e
#     &response_type=code
#     &redirect_uri=http://localhost:{port}/callback
#     &scope=org:create_api_key user:profile user:inference user:sessions:claude_code user:mcp_servers
#     &code_challenge={base64url(sha256(code_verifier))}
#     &code_challenge_method=S256
#     &state={random_state}
#     [&orgUUID={org_uuid}]
#
# Claude.ai OAuth:
#   https://claude.ai/oauth/authorize
#     (same params as above)
#
# Scopes (pattern: rg '"user:inference"|"user:profile"|"user:sessions"|"user:mcp_servers"' cli.js):
#   - user:inference         (required for API access)
#   - user:profile           (required for profile info)
#   - user:sessions:claude_code  (required for web sessions)
#   - user:mcp_servers       (required for MCP server access - NEW in v2.1.x)
#   - org:create_api_key     (required for API key creation)

### ----------------------------------------------------------------------------
### 1.2 Token Exchange
### ----------------------------------------------------------------------------
# Pattern: rg "grant_type.*authorization_code" cli.js

# @name tokenExchange
POST {{platformUrl}}/v1/oauth/token
Content-Type: application/json

{
    "grant_type": "authorization_code",
    "code": "{{authCode}}",
    "redirect_uri": "http://localhost:{{port}}/callback",
    "client_id": "{{clientId}}",
    "code_verifier": "{{codeVerifier}}",
    "state": "{{state}}"
}

### Response:
# {
#   "access_token": "...",
#   "refresh_token": "...",
#   "expires_in": 3600,
#   "token_type": "Bearer",
#   "scope": "user:profile user:inference user:sessions:claude_code org:create_api_key"
# }

### ----------------------------------------------------------------------------
### 1.3 Token Refresh
### ----------------------------------------------------------------------------
# Pattern: rg "grant_type.*refresh_token" cli.js

# @name tokenRefresh
POST {{platformUrl}}/v1/oauth/token
Content-Type: application/json

{
    "grant_type": "refresh_token",
    "refresh_token": "{{refreshToken}}",
    "client_id": "{{clientId}}",
    "scope": "user:profile user:inference user:sessions:claude_code"
}


### ============================================================================
### SECTION 2: PROFILE & ACCOUNT
### ============================================================================

### ----------------------------------------------------------------------------
### 2.1 OAuth Profile (with Bearer token)
### ----------------------------------------------------------------------------
# Pattern: rg '/api/oauth/profile' cli.js

# @name oauthProfile
GET {{baseUrl}}/api/oauth/profile
Authorization: Bearer {{accessToken}}
Content-Type: application/json

### Response:
# {
#   "account_uuid": "...",
#   "display_name": "...",
#   "email_address": "...",
#   "has_extra_usage_enabled": true,
#   "organization": {
#     "uuid": "...",
#     "name": "...",
#     "organization_type": "claude_max|claude_pro|claude_enterprise|free"
#   }
# }

### ----------------------------------------------------------------------------
### 2.2 CLI Profile (with API key)
### ----------------------------------------------------------------------------
# Pattern: rg "api/claude_cli_profile" cli.js

# @name cliProfile
GET {{baseUrl}}/api/claude_cli_profile?account_uuid={{accountUuid}}
x-api-key: {{apiKey}}
anthropic-beta: {{oauthBeta}}

### ----------------------------------------------------------------------------
### 2.3 Get User Roles
### ----------------------------------------------------------------------------
# Pattern: rg "ROLES_URL" cli.js

# @name getUserRoles
GET {{baseUrl}}/api/oauth/claude_cli/roles
Authorization: Bearer {{accessToken}}

### Response:
# {
#   "organization_role": "admin|member|...",
#   "workspace_role": "...",
#   "organization_name": "..."
# }

### ----------------------------------------------------------------------------
### 2.4 Create API Key
### ----------------------------------------------------------------------------
# Pattern: rg "API_KEY_URL|create_api_key" cli.js

# @name createApiKey
POST {{baseUrl}}/api/oauth/claude_cli/create_api_key
Authorization: Bearer {{accessToken}}

### Response:
# {
#   "raw_key": "sk-ant-..."
# }

### ----------------------------------------------------------------------------
### ============================================================================
### SECTION 3: ACCOUNT SETTINGS
### ============================================================================

### ----------------------------------------------------------------------------
### 3.1 Get Account Settings
### ----------------------------------------------------------------------------
# Pattern: rg "api/oauth/account/settings" cli.js

# @name getAccountSettings
GET {{baseUrl}}/api/oauth/account/settings
Authorization: Bearer {{accessToken}}
User-Agent: claude-code/{{cliVersion}}

### ----------------------------------------------------------------------------
### 3.2 Update Account Settings (Grove)
### ----------------------------------------------------------------------------
# Pattern: rg "api/oauth/account/settings" cli.js -A 5

# @name updateAccountSettings
PATCH {{baseUrl}}/api/oauth/account/settings
Authorization: Bearer {{accessToken}}
User-Agent: claude-code/{{cliVersion}}
Content-Type: application/json

{
    "grove_enabled": true
}

### ----------------------------------------------------------------------------
### 3.3 Mark Grove Notice Viewed
### ----------------------------------------------------------------------------
# Pattern: rg "grove_notice_viewed" cli.js

# @name markGroveNoticeViewed
POST {{baseUrl}}/api/oauth/account/grove_notice_viewed
Authorization: Bearer {{accessToken}}
User-Agent: claude-code/{{cliVersion}}
Content-Type: application/json

{}

### ----------------------------------------------------------------------------
### 3.4 Get Grove Settings
### ----------------------------------------------------------------------------
# Pattern: rg "api/claude_code_grove" cli.js

# @name getGroveSettings
GET {{baseUrl}}/api/claude_code_grove
Authorization: Bearer {{accessToken}}
User-Agent: claude-cli/{{cliVersion}} (external, cli)

### Response:
# {
#   "grove_enabled": true,
#   "domain_excluded": false,
#   "notice_is_grace_period": true,
#   "notice_reminder_frequency": ...
# }

### ----------------------------------------------------------------------------
### 3.5 Remote Settings (Enterprise / First Party)
### ----------------------------------------------------------------------------
# Pattern: rg "Remote settings:" cli.js
# Verify: rg "/api/claude_code/settings" cli.js

# @name getRemoteSettingsWithApiKey
GET {{baseUrl}}/api/claude_code/settings
x-api-key: {{apiKey}}
User-Agent: claude-cli/{{cliVersion}} (external, cli)
If-None-Match: "{{remoteSettingsChecksum}}"

### Response (200):
# {
#   "settings": { ... },
#   "checksum": "sha256:..."
# }
#
# Response (304): no body (use cached settings)
# Response (404): no settings (treat as {})

###

# @name getRemoteSettingsWithOAuth
GET {{baseUrl}}/api/claude_code/settings
Authorization: Bearer {{accessToken}}
anthropic-beta: {{oauthBeta}}
User-Agent: claude-cli/{{cliVersion}} (external, cli)
If-None-Match: "{{remoteSettingsChecksum}}"

### ----------------------------------------------------------------------------
### 3.6 Get Policy Limits (First Party / Enterprise)
### ----------------------------------------------------------------------------
# Pattern: rg "policy_limits" cli.js
# Only available for first-party deployments

# @name getPolicyLimits
GET {{baseUrl}}/api/claude_code/policy_limits
x-api-key: {{apiKey}}
User-Agent: claude-cli/{{cliVersion}} (external, cli)

### ----------------------------------------------------------------------------
### 3.7 Get User Settings (NEW in v2.1.x)
### ----------------------------------------------------------------------------
# Pattern: rg "user_settings" cli.js
# Requires user:inference scope

# @name getUserSettings
GET {{baseUrl}}/api/claude_code/user_settings
Authorization: Bearer {{accessToken}}
anthropic-beta: {{oauthBeta}}
User-Agent: claude-cli/{{cliVersion}} (external, cli)


