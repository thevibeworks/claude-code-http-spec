### ============================================================================
### SECTION 7: MESSAGES API (SDK)
### ============================================================================
# Pattern: rg '"/v1/messages"' cli.js

### ----------------------------------------------------------------------------
### 7.1 Create Message
### ----------------------------------------------------------------------------
# Pattern: rg "post.*v1/messages" cli.js
# v2.1.63: interleaved-thinking GA, many betas graduated
# v2.1.76: claude-opus-4-1 added
# Known models: claude-opus-4-6, claude-sonnet-4-6, claude-opus-4-1, claude-opus-4-1-20250805

# @name createMessage
POST {{baseUrl}}/v1/messages?beta=true
Content-Type: application/json
x-api-key: {{apiKey}}
anthropic-version: {{version}}
anthropic-beta: compact-2026-01-12,context-1m-2025-08-07
X-Stainless-Lang: js
X-Stainless-Package-Version: {{stainlessVersion}}
X-Stainless-OS: Linux
X-Stainless-Arch: x64
X-Stainless-Runtime: node
X-Stainless-Runtime-Version: v22.0.0

{
    "model": "claude-sonnet-4-6",
    "max_tokens": 8192,
    "messages": [
        {
            "role": "user",
            "content": "Hello, Claude!"
        }
    ],
    "stream": false
}

### ----------------------------------------------------------------------------
### 7.2 Create Message (Streaming)
### ----------------------------------------------------------------------------
# Pattern: rg "stream.*true" cli.js

# @name createMessageStream
POST {{baseUrl}}/v1/messages?beta=true
Content-Type: application/json
x-api-key: {{apiKey}}
anthropic-version: {{version}}
anthropic-beta: compact-2026-01-12
X-Stainless-Helper-Method: stream

{
    "model": "claude-sonnet-4-6",
    "max_tokens": 8192,
    "messages": [
        {
            "role": "user",
            "content": "Hello!"
        }
    ],
    "stream": true
}

### ----------------------------------------------------------------------------
### 7.3 Count Tokens
### ----------------------------------------------------------------------------
# Pattern: rg "count_tokens" cli.js

# @name countTokens
POST {{baseUrl}}/v1/messages/count_tokens?beta=true
Content-Type: application/json
x-api-key: {{apiKey}}
anthropic-version: {{version}}
# token-counting-2024-11-01 graduated to GA in v2.1.63

{
    "model": "claude-sonnet-4-6",
    "messages": [
        {
            "role": "user",
            "content": "Count these tokens"
        }
    ]
}

### ----------------------------------------------------------------------------
### 7.4 Legacy Complete API
### ----------------------------------------------------------------------------
# Pattern: rg "/v1/complete" cli.js

# @name legacyComplete
POST {{baseUrl}}/v1/complete
Content-Type: application/json
x-api-key: {{apiKey}}
anthropic-version: {{version}}

{
    "model": "claude-2.1",
    "prompt": "\n\nHuman: Hello\n\nAssistant:",
    "max_tokens_to_sample": 256
}


