#   HEAD /api/hello
#
# Users:
#   GET  /api/users/:id                               (NEW in v2.1.139)
#
# === ANTHROPIC API v1 (SDK Endpoints) ===
#
# Messages:
#   POST /v1/messages
#   POST /v1/messages?beta=true
#   POST /v1/messages/count_tokens
#   POST /v1/messages/count_tokens?beta=true
#
# Message Batches:
#   GET    /v1/messages/batches
#   POST   /v1/messages/batches
#   GET    /v1/messages/batches/{id}
#   DELETE /v1/messages/batches/{id}
#   POST   /v1/messages/batches/{id}/cancel
#
# Files:
#   GET    /v1/files
#   POST   /v1/files
#   GET    /v1/files/{id}
#   GET    /v1/files/{id}/content
#   DELETE /v1/files/{id}
#
# Models:
#   GET  /v1/models
#   GET  /v1/models/{id}
#
# Skills:
#   GET    /v1/skills
#   POST   /v1/skills
#   GET    /v1/skills/{id}
#   DELETE /v1/skills/{id}
#   GET    /v1/skills/{id}/versions
#   POST   /v1/skills/{id}/versions
#   GET    /v1/skills/{id}/versions/{versionId}
#   DELETE /v1/skills/{id}/versions/{versionId}
#
# Legacy:
#   POST /v1/complete
#
# Managed Agents (NEW in v2.1.139, beta: managed-agents-2026-04-01):
#   POST /v1/agents
#   GET  /v1/agents/{id}
#   POST /v1/agents/{id}                             (update)
#   GET  /v1/agents/{id}/versions
#
# Memory Stores (NEW in v2.1.139):
#   POST /v1/memory_stores/{id}/memories
#   GET  /v1/memory_stores/{id}/memories
#
# Vaults (NEW in v2.1.139):
#   POST /v1/vaults/{id}/credentials
#   GET  /v1/vaults/{id}/credentials
#
# User Profiles (NEW in v2.1.139):
#   GET  /v1/user_profiles
#
# Code Proxy (NEW in v2.1.139):
#   GET  /v1/code/egress/gateway
#   GET  /v1/code/upstreamproxy
#
# === WEB SESSIONS (api.anthropic.com) ===
#
#   GET  /v1/sessions
#   POST /v1/sessions
#   GET  /v1/sessions/{id}
#   GET  /v1/sessions/{id}/events
#   POST /v1/sessions/{id}/events
#   WSS  /v1/sessions/ws/{id}/subscribe         (WebSocket)
#   GET  /v1/environment_providers
#   PUT  /v1/session_ingress/session/{id}
#   GET  /v1/session_ingress/session/{id}
#
# === MCP SERVERS ===
#
#   GET  /v1/mcp_servers                        (requires user:mcp_servers scope)
#   POST /v1/mcp/{server_id}                    (via mcp-proxy.anthropic.com)
#   POST /v1/toolbox/shttp/mcp/{server_id}
#
# === VOICE / SPEECH (NEW in v2.1.63) ===
#
#   WSS  /api/ws/speech_to_text/voice_stream    (WebSocket - voice mode)
#
# === REMOTE CONTROL (NEW in v2.1.63) ===
#
#   WSS  wss://bridge.claudeusercontent.com     (Remote Control bridge)
#
# === PLATFORM (platform.claude.com - was console.anthropic.com) ===
#
#   GET  /oauth/authorize
#   POST /v1/oauth/token
#   GET  /v1/oauth/hello
#   GET  /.well-known/oauth-authorization-server
#
# === CLAUDE.AI ===
#
#   GET /oauth/authorize
#   GET /api/web/domain_info
#
# === GROWTHBOOK (Feature Flags) ===
#
#   GET  {host}/api/features/{clientKey}
#   POST {host}/api/eval/{clientKey}
#   SSE  {host}/sub/{clientKey}
#
# === CDN (Binary Distribution) ===
#
#   GET https://downloads.claude.ai/claude-code-releases/{channel}
#   GET https://downloads.claude.ai/claude-code-releases/{version}/manifest.json
#   GET https://downloads.claude.ai/claude-code-releases/{version}/{platform}/{file}
#
# === EXTERNAL SERVICES ===
#
# Datadog:
#   POST https://http-intake.logs.datadoghq.com/api/v2/logs
#
# Statsig (removed in v2.1.63 - URLs no longer hardcoded)
#
# GitHub:
#   GET https://raw.githubusercontent.com/anthropics/claude-code/refs/heads/main/CHANGELOG.md
#
# Docs:
#   GET https://code.claude.com/docs/en/claude_code_docs_map.md
#   GET https://docs.claude.com/en/api/agent_sdk_docs_map.md
#
# Connectivity:
#   HEAD http://1.1.1.1
#
# === EXTRACTION COMMANDS ===
#
# Find all axios calls:
#   rg "XQ\.(get|post|put|patch|delete|head)\(" cli.js -n
#
# Find all SDK client calls:
#   rg "this\._client\.(get|post|delete|getAPIList)\(" cli.js -n
#
# Find all hardcoded URLs:
#   rg -o 'https://[^"'\'']+' cli.js | sort -u
#
# Find all dynamic API paths:
#   rg '\$\{o9\(\)\.BASE_API_URL\}' cli.js -n
