#   DELETE /v1/skills/{id}/versions/{versionId}
#
# Legacy:
#   POST /v1/complete
#
# === WEB SESSIONS (api.anthropic.com) ===
#
#   GET  /v1/sessions
#   POST /v1/sessions
#   GET  /v1/sessions/{id}
#   GET  /v1/sessions/{id}/events
