### ============================================================================
### APPENDIX B: HEADERS REFERENCE
### ============================================================================
#
# Authentication:
#   Authorization: Bearer <access_token>    (OAuth)
#   x-api-key: <api_key>                    (API key)
#
# API Version:
#   anthropic-version: 2023-06-01
#   anthropic-beta: <beta-flags>
#
# Organization:
#   x-organization-uuid: <org_uuid>
#
# User-Agent formats:
#   claude-cli/2.0.58 (external, cli)                    - Qp() for OAuth requests
#   claude-cli/2.0.58 (external, cli, agent-sdk/x.y.z)   - with SDK version
#   claude-code/2.0.58                                   - LF() for internal APIs
#
# Stainless SDK headers (auto-generated by SDK):
#   X-Stainless-Lang: js
#   X-Stainless-Package-Version: 0.70.0
#   X-Stainless-OS: Linux|MacOS|Windows|...
#   X-Stainless-Arch: x64|arm64|...
#   X-Stainless-Runtime: node|deno|edge|browser:...
#   X-Stainless-Runtime-Version: v22.0.0
#   X-Stainless-Helper-Method: stream (for streaming)
#
# Content:
#   Content-Type: application/json
#   Accept: application/binary (for file downloads)
#
# Caching:
#   Cache-Control: no-cache (for health checks)


### ============================================================================
### APPENDIX C: SCOPES REFERENCE
### ============================================================================
# Pattern: rg '"user:inference"|"user:profile"|"user:sessions"' cli.js
#
# Full scopes (Fp0 - for initial authorization):
#   org:create_api_key
#   user:profile
#   user:inference
#   user:sessions:claude_code
#
# Session scopes (mH1 - for token refresh):
#   user:profile
#   user:inference
#   user:sessions:claude_code
#
# Minimal scopes (G64 - for API key creation):
#   org:create_api_key
#   user:profile
#
# Inference scope (vxA):
#   user:inference


