### ----------------------------------------------------------------------------
### 8.1 Create Batch
### ----------------------------------------------------------------------------

# @name createBatch
POST {{baseUrl}}/v1/messages/batches?beta=true
Content-Type: application/json
x-api-key: {{apiKey}}
anthropic-version: {{version}}
# message-batches-2024-09-24 graduated to GA in v2.1.63

{
    "requests": [
        {
            "custom_id": "req-1",
            "params": {
                "model": "claude-sonnet-4-6",
                "max_tokens": 1024,
                "messages": [{"role": "user", "content": "Hello"}]
            }
        }
    ]
}

