### ============================================================================
### SECTION 12: WEB SESSIONS API
### ============================================================================
# Pattern: rg "/v1/sessions" cli.js

### ----------------------------------------------------------------------------
### 12.1 List Sessions
### ----------------------------------------------------------------------------

# @name listSessions
GET {{baseUrl}}/v1/sessions
Authorization: Bearer {{accessToken}}
Content-Type: application/json
anthropic-version: {{version}}
x-organization-uuid: {{orgUuid}}

### Response:
# {
#   "data": [
#     {
#       "id": "...",
#       "title": "...",
#       "session_context": {
#         "sources": [{"type": "git_repository", "url": "..."}],
#         "outcomes": [...]
#       }
#     }
#   ]
# }

### ----------------------------------------------------------------------------
### 12.2 Create Session
### ----------------------------------------------------------------------------
# Pattern: rg 'XQ\.post.*v1/sessions[^/]' cli.js (indirect - see line with E = `${o9().BASE_API_URL}/v1/sessions`)
# Verified at: rg 'BASE_API_URL\}/v1/sessions"' cli.js

# @name createSession
POST {{baseUrl}}/v1/sessions
Authorization: Bearer {{accessToken}}
Content-Type: application/json
anthropic-version: {{version}}
x-organization-uuid: {{orgUuid}}

{
    "title": "Session title",
    "events": [
        {
            "type": "event",
            "data": {
                "uuid": "{{eventUuid}}",
                "session_id": "",
                "type": "user",
                "parent_tool_use_id": null,
                "message": {
                    "role": "user",
                    "content": "Initial message"
                }
            }
        }
    ],
    "session_context": {
        "sources": [
            {
                "type": "git_repository",
                "url": "https://github.com/owner/repo",
                "revision": "main"
            }
        ],
        "outcomes": [
            {
                "type": "git_repository",
                "git_info": {
                    "type": "github",
                    "repo": "owner/repo",
                    "branches": ["claude/branch-name"]
                }
            }
        ],
        "model": "claude-sonnet-4-6"
    },
    "environment_id": "{{environmentId}}"
}

### Response:
# {
#   "id": "session_...",
#   "title": "Session title"
# }

### ----------------------------------------------------------------------------
### 12.3 Get Session
### ----------------------------------------------------------------------------

# @name getSession
GET {{baseUrl}}/v1/sessions/{{sessionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json
anthropic-version: {{version}}
x-organization-uuid: {{orgUuid}}

