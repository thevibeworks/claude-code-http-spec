# Statsig:
#   GET  https://featureassets.org/v1/initialize
#   GET  https://api.statsigcdn.com/v1/download_config_specs
#   GET  https://prodregistryv2.org/v1/rgstr
#   POST https://statsigapi.net/v1/sdk_exception
#
# GitHub:
#   GET https://raw.githubusercontent.com/anthropics/claude-code/refs/heads/main/CHANGELOG.md
#
# Docs:
#   GET https://code.claude.com/docs/en/claude_code_docs_map.md
#   GET https://docs.claude.com/en/api/agent_sdk_docs_map.md
#
# Connectivity:
#   HEAD http://1.1.1.1
#
# === EXTRACTION COMMANDS ===
#
# Find all axios calls:
#   rg "XQ\.(get|post|put|patch|delete|head)\(" cli.js -n
#
# Find all SDK client calls:
#   rg "this\._client\.(get|post|delete|getAPIList)\(" cli.js -n
#
# Find all hardcoded URLs:
#   rg -o 'https://[^"'\'']+' cli.js | sort -u
#
# Find all dynamic API paths:
#   rg '\$\{o9\(\)\.BASE_API_URL\}' cli.js -n
