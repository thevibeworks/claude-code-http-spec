### 14.2 MCP Server HTTP Proxy
### ----------------------------------------------------------------------------
# Pattern: rg 'MCP_PROXY_PATH|MCP_PROXY_URL' cli.js
# Proxies HTTP requests to MCP servers via Anthropic's proxy

# @name mcpServerProxy
POST {{mcpProxyUrl}}/v1/mcp/{{serverId}}
Content-Type: application/json
anthropic-beta: {{mcpBeta}}
Authorization: Bearer {{accessToken}}

{
    "method": "POST",
    "path": "/",
    "body": {}
}


