### SECTION 29: PLUGIN MARKETPLACE (User-Configured URLs)
### ============================================================================
# Pattern: rg "Plugin-Manager|\.mcpb" cli.js
#
# These are NOT fixed Anthropic endpoints - they are user-provided URLs:
# - Marketplace: user adds via "/plugin marketplace add <path/url>"
# - MCPB bundles: user-specified .mcpb or .dxt files (local or remote)

### ----------------------------------------------------------------------------
### 29.1 Fetch Plugin Marketplace (user-provided URL)
### ----------------------------------------------------------------------------

# @name fetchMarketplace
# URL is user-configured, not a fixed endpoint
GET {{marketplaceUrl}}
User-Agent: Claude-Code-Plugin-Manager

### ----------------------------------------------------------------------------
### 29.2 Download MCPB Bundle (user-provided URL)
### ----------------------------------------------------------------------------
# URL must end with .mcpb or .dxt

# @name downloadMcpb
# URL is user-configured, not a fixed endpoint
GET {{mcpbUrl}}


### ============================================================================
### SECTION 30: MCP SERVER PROXY (Cross-reference)
### ============================================================================
# See Section 14 for MCP Server endpoints:
#   - 14.1 List MCP Servers
#   - 14.2 MCP Server HTTP Proxy (via mcp-proxy.anthropic.com)
#   - 14.3 MCP Server via Toolbox (via api.anthropic.com)


### ============================================================================
### SECTION 31: AWS SIGNIN (Bedrock OAuth2)
### ============================================================================
# Pattern: rg "signin\.aws|CreateOAuth2Token" cli.js
# Used for AWS IAM Identity Center OAuth2 token exchange (Bedrock access)
# Note: This endpoint was present since v2.0.69 but undocumented

@signinAwsUrl = https://{{awsRegion}}.signin.aws.amazon.com
@signinAwsCnUrl = https://{{awsRegion}}.signin.amazonaws.cn

### ----------------------------------------------------------------------------
### 31.1 Create OAuth2 Token (Authorization Code Grant)
### ----------------------------------------------------------------------------
# Pattern: rg 'CreateOAuth2Token' cli.js -B 10 -A 30
# Exchange authorization code for tokens

# @name awsSigninTokenAuthCode
POST {{signinAwsUrl}}/v1/token
Content-Type: application/json

{
    "clientId": "{{awsClientId}}",
    "grantType": "authorization_code",
    "code": "{{authorizationCode}}",
    "redirectUri": "{{redirectUri}}",
    "codeVerifier": "{{pkceCodeVerifier}}"
}

# Response:
# {
#     "accessToken": "...",
#     "tokenType": "Bearer",
#     "expiresIn": 3600,
#     "refreshToken": "...",
#     "idToken": "..."
# }

### ----------------------------------------------------------------------------
### 31.2 Refresh OAuth2 Token
### ----------------------------------------------------------------------------
# Pattern: rg 'refreshToken.*grantType|grantType.*refresh' cli.js

# @name awsSigninTokenRefresh
POST {{signinAwsUrl}}/v1/token
Content-Type: application/json

{
    "clientId": "{{awsClientId}}",
    "grantType": "refresh_token",
    "refreshToken": "{{awsRefreshToken}}"
}

# Response: Same as 31.1

# Error codes:
#   AUTHCODE_EXPIRED
#   INSUFFICIENT_PERMISSIONS
#   INVALID_REQUEST
#   SERVER_ERROR (server_error)
#   TOKEN_EXPIRED
#   USER_CREDENTIALS_CHANGED


