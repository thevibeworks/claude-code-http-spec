#   anthropic-beta: <beta-flags>
#
# Organization:
#   x-organization-uuid: <org_uuid>
#
# User-Agent formats:
#   claude-cli/{version} (external, cli)                  - for OAuth requests
#   claude-cli/{version} (external, cli, agent-sdk/x.y.z) - with SDK version
#   claude-code/{version}                                - for internal APIs
#
# Stainless SDK headers (auto-generated by SDK):
#   X-Stainless-Lang: js
#   X-Stainless-Package-Version: 0.74.0   (updated in v2.1.63)
#   X-Stainless-OS: Linux|MacOS|Windows|...
#   X-Stainless-Arch: x64|arm64|...
#   X-Stainless-Runtime: node|deno|edge|browser:...
#   X-Stainless-Runtime-Version: v22.0.0
#   X-Stainless-Helper-Method: stream (for streaming)
#
# Content:
#   Content-Type: application/json
#   Accept: application/binary (for file downloads)
#
# Caching:
#   Cache-Control: no-cache (for health checks)
#
# Rate Limiting (NEW in v2.1.63 - unified rate limit headers):
