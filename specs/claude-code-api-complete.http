### ----------------------------------------------------------------------------
### 15.2 Submit Metrics
### ----------------------------------------------------------------------------
# Pattern: rg "api/claude_code/metrics" cli.js

# @name submitMetrics
POST {{baseUrl}}/api/claude_code/metrics
Authorization: Bearer {{accessToken}}
Content-Type: application/json
User-Agent: claude-code/{{cliVersion}}

{
    "metrics": []
}

