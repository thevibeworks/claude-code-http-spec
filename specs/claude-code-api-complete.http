#   POST /v1/oauth/revoke
#   GET  /v1/oauth/hello
#   GET  /.well-known/oauth-authorization-server
#
# === CLAUDE.AI ===
#
#   GET /oauth/authorize
#   GET /api/web/domain_info
#
# === GROWTHBOOK (Feature Flags) ===
#
#   GET  {host}/api/features/{clientKey}
#   POST {host}/api/eval/{clientKey}
#   SSE  {host}/sub/{clientKey}
#
# === CDN (Binary Distribution) ===
#
#   GET https://downloads.claude.ai/claude-code-releases/{channel}
